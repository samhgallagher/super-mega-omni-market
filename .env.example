# AWS credentials (for local dev — on Amplify, IAM role is used instead)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB
DYNAMODB_TABLE_NAME=smom

# Auth — minimum 32 characters, used to sign and seal session tokens
NUXT_SESSION_PASSWORD=

# Comma-separated list of admin email addresses
ADMIN_EMAILS=
